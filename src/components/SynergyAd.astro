---
import AdSlot from "./AdSlot.astro";
// "The Synergy Engine" — a sponsored buzzword generator. One click, infinite
// thought leadership. Contrast to the cone: button-driven, not a slider.
---

<AdSlot
  eyebrow="Thought leadership, on tap"
  headline="The Synergy Engine&trade;"
  sub="Out of things to say in the meeting? Generate infinite alignment. First 10,000 paradigms free."
>
  <div class="synergy" data-synergy>
    <p class="synergy__phrase" data-synergy-phrase>
      Leverage cross-functional synergies going forward.
    </p>

    <div class="synergy__row">
      <button type="button" class="synergy__btn" data-synergy-btn>
        Generate synergy
      </button>
      <p class="synergy__count">
        <span data-synergy-count>1,204,915</span> paradigms shifted today
      </p>
    </div>

    <p class="synergy__fine">
      *Results not guaranteed. May cause déjà vu, meetings about meetings, and
      an inexplicable urge to circle back.
    </p>
  </div>
</AdSlot>

<script>
  const VERBS = [
    "Leverage",
    "Synergize",
    "Operationalize",
    "Unlock",
    "Streamline",
    "Disrupt",
    "Right-size",
    "Circle back on",
    "Double-click into",
    "Ideate around",
    "Sunset",
    "Harden",
  ];
  const ADJ = [
    "cross-functional",
    "cloud-native",
    "agile",
    "frictionless",
    "scalable",
    "data-driven",
    "best-in-class",
    "holistic",
    "next-gen",
    "low-hanging",
    "mission-critical",
    "blockchain-enabled",
  ];
  const NOUNS = [
    "synergies",
    "paradigms",
    "deliverables",
    "learnings",
    "touchpoints",
    "verticals",
    "bandwidth",
    "north stars",
    "workstreams",
    "value streams",
    "action items",
    "KPIs",
  ];
  const TAILS = [
    "going forward.",
    "at scale.",
    "to move the needle.",
    "before EOD.",
    "this sprint.",
    "to delight stakeholders.",
    "in the cloud.",
    "holistically.",
  ];

  const pick = (arr: string[]) => arr[Math.floor(Math.random() * arr.length)];
  const phrase = () =>
    `${pick(VERBS)} ${pick(ADJ)} ${pick(NOUNS)} ${pick(TAILS)}`;

  for (const root of document.querySelectorAll<HTMLElement>("[data-synergy]")) {
    const btn = root.querySelector<HTMLButtonElement>("[data-synergy-btn]");
    const out = root.querySelector<HTMLElement>("[data-synergy-phrase]");
    const countEl = root.querySelector<HTMLElement>("[data-synergy-count]");
    if (!btn || !out || !countEl) continue;

    let count = parseInt(countEl.textContent!.replace(/\D/g, ""), 10) || 0;

    btn.addEventListener("click", () => {
      let next = phrase();
      // never repeat the current phrase back-to-back
      while (next === out.textContent) next = phrase();
      out.textContent = next;
      count += 1 + Math.floor(Math.random() * 40);
      countEl.textContent = count.toLocaleString("en-US");
    });
  }
</script>

<style>
  .synergy__phrase {
    min-height: 2.4em;
    margin: 0 0 1.75rem;
    font-size: clamp(1.35rem, 3.2vw, 2rem);
    line-height: 1.3;
    color: var(--acid);
  }

  .synergy__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .synergy__btn {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--rust);
    border: none;
    padding: 0.85rem 1.5rem;
    cursor: pointer;
    transition:
      background 0.15s ease,
      transform 0.08s ease;
  }

  .synergy__btn:hover {
    background: var(--rust-bright);
  }

  .synergy__btn:active {
    transform: translateY(1px);
  }

  .synergy__count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--bone-dim);
  }

  .synergy__count [data-synergy-count] {
    color: var(--rust-bright);
  }

  .synergy__fine {
    margin: 1.75rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--bone-faint);
    font-style: italic;
  }
</style>
